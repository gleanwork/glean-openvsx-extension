{
  "name": "glean",
  "displayName": "Glean",
  "description": "Connect Cursor to your company's knowledge with Glean",
  "version": "0.1.2",
  "publisher": "glean",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gleanwork/glean-extension-mdm"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "MCP"
  ],
  "extensionDependencies": [
    "anysphere.cursor-mcp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Glean",
      "properties": {
        "glean.mcpServerUrl": {
          "type": "string",
          "default": "",
          "description": "MCP server URL for Glean. When set, this takes priority over system and user config files."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out glean.vsix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
